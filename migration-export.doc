## SubscriptionValidationService.php
Path: app/Services/SubscriptionValidationService.php

```php
<?php

namespace App\Services;

use App\Models\Subscription;
use App\Models\User;
use Illuminate\Support\Facades\DB;
use Illuminate\Validation\ValidationException;

class SubscriptionValidationService
{
    public function validateOwnership(User $user): void
    {
        if (! $user->hasRole('provider')) {
            throw ValidationException::withMessages([
                'user_id' => 'Only providers may own subscriptions.',
            ]);
        }
    }

    public function validateDates(
        User $provider,
        Subscription $subscription
    ): void {
        if ($subscription->ends_at <= $subscription->starts_at) {
            throw ValidationException::withMessages([
                'ends_at' => 'End date must be later than start date.',
            ]);
        }

        // lockForUpdate inside a transaction prevents concurrent inserts from both
        // passing the overlap check simultaneously (TOCTOU race condition).
        // MySQL InnoDB supports nested transactions via savepoints, so this is safe
        // when called from within an outer transaction (e.g., a Filament action).
        DB::transaction(function () use ($provider, $subscription) {
            $existingId = $subscription->getKey() ?? 0;

            $overlap = Subscription::query()
                ->where('user_id', $provider->id)
                ->where('id', '!=', $existingId)
                ->where(function ($query) use ($subscription) {
                    $query
                        ->whereBetween('starts_at', [
                            $subscription->starts_at,
                            $subscription->ends_at,
                        ])
                        ->orWhereBetween('ends_at', [
                            $subscription->starts_at,
                            $subscription->ends_at,
                        ])
                        ->orWhere(function ($q) use ($subscription) {
                            $q->where('starts_at', '<=', $subscription->starts_at)
                                ->where('ends_at', '>=', $subscription->ends_at);
                        });
                })
                ->lockForUpdate()
                ->exists();

            if ($overlap) {
                throw ValidationException::withMessages([
                    'starts_at' => 'Subscription dates overlap.',
                ]);
            }
        });
    }
}
```

## UserSuspensionService.php
Path: app/Services/UserSuspensionService.php

```php
<?php

namespace App\Services;

use App\Models\User;
use Illuminate\Support\Facades\Auth;

class UserSuspensionService
{
    public function suspend(User $user, string $reason): void
    {
        $user->update([
            'is_suspended'      => true,
            'suspension_reason' => $reason,
            'suspended_at'      => now(),
            'suspended_by'      => Auth::id(),
        ]);
    }

    public function reinstate(User $user, string $reason): void
    {
        $user->update([
            'is_suspended'        => false,
            'reinstatement_reason'=> $reason,
            'reinstated_at'       => now(),
            'reinstated_by'       => Auth::id(),
        ]);
    }
}
```

