APP_NAME=Delni
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://delni.ly

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=delni
DB_USERNAME=delni
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CORS_ALLOWED_ORIGINS=https://delni.ly,https://www.delni.ly
TRUSTED_PROXIES=127.0.0.1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
RESEND_KEY=
MAIL_FROM_ADDRESS=noreply@delni.ly
MAIL_FROM_NAME=Delni

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Set true only for demo deployments that need the shared-password provider accounts.
SEED_DEMO_PROVIDERS=false

WHATSAPP_NUMBER=218911111111
WHATSAPP_BUSINESS_NAME=Delni

# Custom URL scheme for deep-linking password-reset emails into the mobile app
MOBILE_DEEP_LINK_SCHEME=delni

# Scales ONLY the public read rate limiters (home/search/top-rated/provider-detail/suggestions).
# Leave at 1 in normal operation. Raise temporarily (e.g. 20) to load test from a single IP,
# then reset to 1. Auth/login/register/password limiters are never affected.
PUBLIC_RATE_LIMIT_MULTIPLIER=1

VITE_APP_NAME="${APP_NAME}"
