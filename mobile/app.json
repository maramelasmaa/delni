{
  "expo": {
    "name": "دلني",
    "slug": "delni",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "delni",
    "userInterfaceStyle": "automatic",
    "locales": {
      "ar": "./locales/ar.json"
    },
    "extra": {
      "supportsRTL": true,
      "forcesRTL": true,
      "eas": {
        "projectId": ""
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ly.delni.app",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "package": "ly.delni.app",
      "targetSdkVersion": 36,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0B1A34"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    }
  }
}
